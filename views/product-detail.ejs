<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= product.name %> - Eglanto</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

    <style>
        @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Inter:wght@300;400;500&display=swap');
        body { font-family: 'Inter', system-ui, sans-serif; }
        .heading-font { font-family: 'Playfair Display', serif; }
    </style>
</head>
<body class="bg-[#f8f1e9]">

    <nav class="bg-white border-b sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-8 py-6 flex items-center justify-between">
            <div class="flex gap-8 text-sm font-medium">
                <a href="/" class="hover:text-amber-800">Home</a>
                <a href="/products" class="hover:text-amber-800">Products</a>
            </div>
            <h1 class="text-3xl heading-font">Eglanto</h1>
            <div class="flex gap-6 text-xl">
                <button><i class="fas fa-search"></i></button>
                <button><i class="far fa-heart"></i></button>
                <button><i class="fas fa-shopping-bag"></i></button>
            </div>
        </div>
    </nav>

    <div class="max-w-7xl mx-auto px-8 py-16">
        <div class="grid md:grid-cols-2 gap-16">
            <!-- Image Gallery -->
            <div>
                <div class="relative rounded-3xl overflow-hidden bg-white shadow-2xl">
                    <img id="mainImage" src="<%= product.image %>"
                         class="w-full h-auto object-cover transition-opacity duration-500" alt="<%= product.name %>">
                </div>
                <div class="flex gap-4 mt-6" id="thumbnails">
                    <% product.images.forEach(img => { %>
                        <img src="<%= img %>" onclick="changeImage(this)"
                             class="w-20 h-20 object-cover rounded-2xl cursor-pointer border-2 border-transparent hover:border-amber-800">
                    <% }); %>
                </div>
            </div>

            <!-- Info -->
            <div class="space-y-8">
                <div>
                    <p class="uppercase text-amber-700 text-sm tracking-widest"><%= product.category %></p>
                    <h1 class="heading-font text-5xl mt-3"><%= product.name %></h1>
                    <p class="text-4xl font-light mt-6">$<%= product.price %></p>
                </div>

                <div>
                    <h3 class="font-medium mb-3">Description</h3>
                    <p class="text-gray-600 leading-relaxed"><%= product.description %></p>
                </div>

                <button onclick="addToCart()"
                        class="w-full bg-amber-950 text-white py-6 rounded-3xl text-lg hover:bg-black transition">
                    Add to Bag
                </button>
            </div>
        </div>
    </div>

    <script>
        function changeImage(imgElement) {
            document.getElementById('mainImage').src = imgElement.src;
        }

        function addToCart() {
            alert(`✅ <%= product.name %> has been added to your bag!`);
        }
    </script>
</body>
</html>